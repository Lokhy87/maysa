{% extends 'base.html.twig' %}

{% block title %}Massage{% endblock %}

{% block body %}
    <h1>Massage</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ massage.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ massage.name }}</td>
            </tr>
            <tr>
                <th>Subtitle</th>
                <td>{{ massage.subtitle }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ massage.description }}</td>
            </tr>
            <tr>
                <th>Image</th>
                <td>{{ massage.image }}</td>
            </tr>
            <tr>
                <th>Active</th>
                <td>{{ massage.active ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Position</th>
                <td>{{ massage.position }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_massage_index') }}">back to list</a>

    <a href="{{ path('app_massage_edit', {'id': massage.id}) }}">edit</a>

    {{ include('massage/_delete_form.html.twig') }}
{% endblock %}
