{% extends 'base.html.twig' %}

{% block title %}MassagePrice index{% endblock %}

{% block body %}
    <h1>MassagePrice index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Duration</th>
                <th>Price</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for massage_price in massage_prices %}
            <tr>
                <td>{{ massage_price.id }}</td>
                <td>{{ massage_price.duration }}</td>
                <td>{{ massage_price.price }}</td>
                <td>
                    <a href="{{ path('app_massage_price_show', {'id': massage_price.id}) }}">show</a>
                    <a href="{{ path('app_massage_price_edit', {'id': massage_price.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_massage_price_new') }}">Create new</a>
{% endblock %}
