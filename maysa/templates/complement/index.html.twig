{% extends 'base.html.twig' %}

{% block title %}Complement index{% endblock %}

{% block body %}
    <h1>Complement index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Category</th>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for complement in complements %}
            <tr>
                <td>{{ complement.id }}</td>
                <td>{{ complement.category }}</td>
                <td>{{ complement.name }}</td>
                <td>{{ complement.description }}</td>
                <td>{{ complement.price }}</td>
                <td>
                    <a href="{{ path('app_complement_show', {'id': complement.id}) }}">show</a>
                    <a href="{{ path('app_complement_edit', {'id': complement.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_complement_new') }}">Create new</a>
{% endblock %}
